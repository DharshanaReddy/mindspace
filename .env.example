# ── LLM Provider ──────────────────────────────────────────────────────────────
# Free tier available at https://console.groq.com
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.1-70b-versatile

# ── LangSmith Observability (optional, free at smith.langchain.com) ────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=mindspace

# ── Database ───────────────────────────────────────────────────────────────────
# SQLite (default, zero config for local dev):
DATABASE_URL=sqlite+aiosqlite:///./mindspace.db
# PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/mindspace

# ── Auth ───────────────────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-in-production

# ── Runtime ────────────────────────────────────────────────────────────────────
BACKEND_URL=http://localhost:8001
APP_ENV=development

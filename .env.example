# Required
OPENAI_API_KEY=your_openai_api_key_here

# LangSmith (free at smith.langchain.com)
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=mindspace

# Database — defaults to SQLite for local dev
# PostgreSQL for production: postgresql+asyncpg://user:pass@host:5432/mindspace
DATABASE_URL=sqlite+aiosqlite:///./mindspace.db

# Auth
JWT_SECRET=change-this-to-a-random-secret-in-production

# Frontend
BACKEND_URL=http://localhost:8001

# Docker only
POSTGRES_PASSWORD=mindspace_dev
